{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5",
    "MAX_MCP_OUTPUT_TOKENS": "6000"
  },
  "includeGitInstructions": false,
  "permissions": {
    "deny": [
      "Read(./node_modules/**)",
      "Read(./dist/**)",
      "Read(./build/**)",
      "Read(./coverage/**)",
      "Read(./.next/**)",
      "Read(./out/**)",
      "Read(./.turbo/**)",
      "Read(./.pnpm-store/**)",
      "Read(./_legacy/**)",
      "Read(./output/**)"
    ],
    "allow": [
      "Bash(cd:*)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "availableModels": [
    "sonnet"
  ],
  "disableAllHooks": true,
  "alwaysThinkingEnabled": false,
  "effortLevel": "low",
  "autoMemoryEnabled": false,
  "mcpServers": {
    "github": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "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"
      }
    },
    "cloudflare": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@cloudflare/mcp-server-cloudflare"
      ],
      "env": {
        "CLOUDFLARE_API_TOKEN": "7c634fbb292a16053bd3059674903eb30fda1"
      }
    },
    "stitch": {
      "type": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "AQ.Ab8RN6KFh9l-4SgtrkbxZ5tzKWEij3YK1alu05EWctOxNzNInQ"
      }
    }
  }
}
